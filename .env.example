# ============================================
# VARIÁVEIS DE AMBIENTE — EXEMPLO
# ============================================
# 1. Copie este arquivo:       cp .env.example .env
# 2. Preencha os valores em .env
# 3. NUNCA commite .env (já está no .gitignore)
# 4. Se adicionar variável nova, atualize AQUI também (sem valor real)
# ============================================

# --- Claude / Anthropic (OBRIGATÓRIO) ---
# Chave do envelope do bootcamp. Limite individual de US$ 20.
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (OBRIGATÓRIO pro bootcamp) ---
# Project Settings > API no dashboard do Supabase
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_ANON_KEY=
# NÃO exponha a service role key no frontend — só use em backend
# SUPABASE_SERVICE_ROLE_KEY=

# --- Vercel (opcional — normalmente via CLI/GitHub integration) ---
# Só precisa se for fazer deploy manual via API
# VERCEL_TOKEN=

# --- Outras integrações (se seu projeto precisar) ---
# OPENAI_API_KEY=
# N8N_WEBHOOK_URL=
# DATABASE_URL=
# GOOGLE_API_KEY=
